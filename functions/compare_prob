prob_diff_values <- function(x) {

prob_diff_values <- x %>% 
  select(class1, c.param, prob_diff) %>% 
  rename(param = c.param) %>% 
    mutate(items = fct_inorder(param),
         class = fct_inorder(class1)) %>% 
  mutate(items = factor(items, labels = item_labels),
         class = factor(class, labels = class_labels)) %>% 
  select(class, items, prob_diff) %>% 
  pivot_wider(names_from = items, values_from = prob_diff) 
return(prob_diff_values)
}


compare_prob <- function(c_model, conx_model) {
  # Extract probability data from c model
  c_prob <- as.data.frame(c_model[["savedata"]]) %>% 
    select(C) %>% 
    rename(cN = C)
  
  # Extract probability data from conx model
  conx_prob <- as.data.frame(conx_model[["savedata"]]) %>%
    select(C) %>% 
    rename(conxN = C)
  
  # Merge probability data
  merge <- cbind(c_prob, conx_prob)
  
  # Calculate counts of mismatched probabilities
  mismatch_counts <- merge %>% 
    filter(cN != conxN) %>% 
    count()
  
  # Create contingency table
  cont_table <- table(merge$cN, merge$conxN)
  
  # Create proportion table
  prop_table <- round(prop.table(cont_table, 1), 3)
  
  # Return results
  return(list(mismatch_counts = mismatch_counts,
              contingency_table = cont_table,
              proportion_table = prop_table))
}
