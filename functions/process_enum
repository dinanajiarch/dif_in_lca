# Extract BIC, aBIC and VLMR from each replication
process_file <- function(file) {

  # Read the file as a dataframe
  data <- read.csv(file, sep = " ", header = FALSE)
  
  # Identify rows with a single numeric value (section identifiers)
  section_indices <- which(apply(data, 1, function(row) {
    values <- na.omit(row)
    length(values) == 1 &&
      grepl("^\\d+$", as.character(values)) &&
      as.numeric(values) != 0
  }))
  
  # Initialize a list to store the extracted values
  extracted_values <- list()
  
  # Loop through each section and extract data
  for (i in seq_along(section_indices)) {

    start <- section_indices[i] + 1  # Start after the section identifier
    end <- if (i < length(section_indices)) section_indices[i + 1] - 1 else nrow(data)
    
    # Extract the section data
    section_data <- data[start:end, ] 
    
    # Extract the last three rows of the section
    last_three_rows <- tail(section_data, 3)

    # Detect the first row (within these last three rows) where the first value is a whole number > 1 and not negative
    row_whole_number_index <- which(last_three_rows[, 1] %% 1 == 0 & last_three_rows[, 1] > 1)[1]
    
    # Check if the index is valid
  if (is.na(row_whole_number_index)) {
    cat("❌ Skipping Replication", data[section_indices[i], 1],
        "in file:", basename(file), "\n")
    next
  }
    # Adjust index to match original section_data
    if (!is.na(row_whole_number_index)) {
      row_whole_number_index <- nrow(section_data) - 3 + row_whole_number_index
    }

    # Capture all rows after and including the detected row
    cleaned_rows <- section_data[seq(row_whole_number_index, nrow(section_data)), , drop = FALSE]
    
    extracted <- c(
      BIC = cleaned_rows[1,4], # BIC
      aBIC = cleaned_rows[1,5], # aBIC
      VLMR = ifelse(is.na(cleaned_rows[2,7]), cleaned_rows[2,1], cleaned_rows[2,7]),  # If VLMR is NA, use (2,1) instead
      par = cleaned_rows[1,1],
      LL = cleaned_rows[1,2]
    )
    
    # Store extracted values with a section identifier
    section_name <- paste0("Replication_", data[section_indices[i], 1])
    extracted_values[[section_name]] <- extracted
  }
  
  return(extracted_values)
}


