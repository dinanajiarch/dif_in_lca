calculate_accuracy_com <- function(extracted_index) {

cleaned_dataset <- extracted_index$extracted_dataset

reps <- extracted_index$replication_counts %>% 
  select(-k) %>% 
  distinct() 

if (!"de" %in% names(cleaned_dataset)) {
  # This tells us which class was selected per fit index
  index_summary <- cleaned_dataset %>%
    group_by(Rep, sim_model, k_split, separation, N, model) %>%
    summarize(
      BIC = k[which.min(BIC)],
      aBIC = k[which.min(aBIC)],
      CAIC = k[which.min(CAIC)],
      AWE = k[which.min(AWE)],
      cmPk = k[which.max(cmPk)]
    )
  
  # Calculates the percentages of correctly identified fit indices
  percentage_ic <- index_summary %>%
    pivot_longer(
      -c(Rep, sim_model, k_split, separation, N, model),
      names_to = "Fit_Index",
      values_to = "Min"
    ) %>%
    group_by(Fit_Index, sim_model, k_split, separation, N, model) %>%
    summarise(
      Class_2 = round(100 * sum(Min == 2) / length(Min), 0),
      Class_3 = round(100 * sum(Min == 3) / length(Min), 0),
      Class_4 = round(100 * sum(Min == 4) / length(Min), 0),
      Class_5 = round(100 * sum(Min == 5) / length(Min), 0),
      Class_6 = round(100 * sum(Min == 6) / length(Min), 0)
    ) %>%
    ungroup()
  
  
  count_ic <- index_summary %>%
    pivot_longer(
      -c(Rep, sim_model, k_split, separation, N, model),
      names_to = "Fit_Index",
      values_to = "Min"
    ) %>%
    group_by(Fit_Index, sim_model, k_split, separation, N, model) %>%
    summarise(
      Class_2 = sum(Min == 2),
      Class_3 = sum(Min == 3),
      Class_4 = sum(Min == 4),
      Class_5 = sum(Min == 5),
      Class_6 = sum(Min == 6)
    ) %>%
    ungroup() %>%
    left_join(reps, by = c("sim_model", "N", "k_split", "separation"), relationship = "many-to-many")
  
  
  percentage_vlmr <- cleaned_dataset %>%
    group_by(Rep, sim_model, k_split, separation, N, model) %>%
    mutate(
      # VLMR: Place a 1 only the first time the condition is met, replace NA with 0
      VLMR_Condition = ifelse(
        VLMR < 0.05 &
          lead(VLMR) > 0.05 &
          cumsum(VLMR < 0.05 &
                   lead(VLMR) > 0.05) == 1,
        # Second condition means that it won't add a 1 if its already there
        1,
        0
      ) %>% replace_na(0)
    ) %>%
    ungroup() %>%
    group_by(Rep, sim_model, k_split, separation, N, model) %>%
    mutate(
      # If no values are less than 0.05 in the group, assign 1 where k == 6
      VLMR_Condition = ifelse(all(VLMR_Condition == 0) &
                                k == 6, 1, VLMR_Condition)
    ) %>%
    ungroup() %>%
    group_by(sim_model, k_split, separation, N, model) %>%
    summarise(
      VLMR_Class_2 = round(100 * sum(VLMR_Condition == 1 &
                                       k == 2) / sum(k == 2), 0),
      VLMR_Class_3 = round(100 * sum(VLMR_Condition == 1 &
                                       k == 3) / sum(k == 3), 0),
      VLMR_Class_4 = round(100 * sum(VLMR_Condition == 1 &
                                       k == 4) / sum(k == 4), 0),
      VLMR_Class_5 = round(100 * sum(VLMR_Condition == 1 &
                                       k == 5) / sum(k == 5), 0),
      VLMR_Class_6 = round(100 * sum(VLMR_Condition == 1 &
                                       k == 6) / sum(k == 6), 0)
    ) %>%
    ungroup() %>%
    pivot_longer(cols = starts_with("VLMR"), names_to = "Fit_Index") %>%
    separate(
      col = Fit_Index,
      into = c("Fit_Index", "Class"),
      extra = "merge",
      sep = "_",
      remove = TRUE                # Remove the original column
    ) %>%
    pivot_wider(names_from = Class, values_from = value)
  
  count_vlmr <- cleaned_dataset %>%
    group_by(Rep, sim_model, k_split, separation, N, model) %>%
    mutate(
      # VLMR: Place a 1 only the first time the condition is met, replace NA with 0
      VLMR_Condition = ifelse(
        VLMR < 0.05 &
          lead(VLMR) > 0.05 &
          cumsum(VLMR < 0.05 &
                   lead(VLMR) > 0.05) == 1,
        # Second condition means that it won't add a 1 if its already there
        1,
        0
      ) %>% replace_na(0)
    ) %>%
    ungroup() %>%
    group_by(Rep, sim_model, k_split, separation, N, model) %>%
    mutate(
      # If no values are less than 0.05 in the group, assign 1 where k == 6
      VLMR_Condition = ifelse(all(VLMR_Condition == 0) &
                                k == 6, 1, VLMR_Condition)
    ) %>%
    ungroup() %>%
    group_by(sim_model, k_split, separation, N, model) %>%
    summarise(
      VLMR_Class_2 = sum(VLMR_Condition == 1 & k == 2),
      VLMR_Class_3 = sum(VLMR_Condition == 1 & k == 3),
      VLMR_Class_4 = sum(VLMR_Condition == 1 & k == 4),
      VLMR_Class_5 = sum(VLMR_Condition == 1 & k == 5),
      VLMR_Class_6 = sum(VLMR_Condition == 1 & k == 6)
    ) %>%
    ungroup() %>%
    pivot_longer(cols = starts_with("VLMR"), names_to = "Fit_Index") %>%
    separate(
      col = Fit_Index,
      into = c("Fit_Index", "Class"),
      extra = "merge",
      sep = "_",
      remove = TRUE                # Remove the original column
    ) %>%
    pivot_wider(names_from = Class, values_from = value) %>%
    left_join(reps, by = c("sim_model", "N", "k_split", "separation"), relationship = "many-to-many")
  
  combined_count <- bind_rows(count_ic, count_vlmr) %>%
    arrange(Fit_Index, separation, k_split, N)

  combined_percentages <- bind_rows(percentage_ic, percentage_vlmr) %>%
    arrange(Fit_Index, separation, k_split, N) %>%
    left_join(
      reps %>% select(sim_model, N, k_split, separation, replication_count),
      by = c("sim_model", "N", "k_split", "separation"), relationship = "many-to-many"
      ) %>%
    rename(Total = replication_count)
  
  
  return(
    list(
      combined_percentages = combined_percentages,
      combined_count = combined_count,
      index_summary = index_summary
    )
  )
  
  
  
} else {
  # This tells us which class was selected per fit index
  index_summary <- cleaned_dataset %>%
    group_by(Rep, sim_model, k_split, separation, N, de, model) %>%
    summarize(
      BIC = k[which.min(BIC)],
      aBIC = k[which.min(aBIC)],
