# Function to bold the highest value in each row within a set of columns
bold_max_per_index <- function(df, cols) {
  df %>%
    rowwise() %>%
    mutate(across(all_of(cols), 
                  ~ ifelse(. == max(c_across(all_of(cols)), na.rm = TRUE), 
                           paste0("**", round(., 3), "**"), 
                           as.character(round(., 3))))) %>%
    ungroup()
}

