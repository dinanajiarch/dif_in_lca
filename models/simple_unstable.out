INPUT INSTRUCTIONS

  TITLE:
  Simple, Unstable Separation
  MONTECARLO:
  NAMES = u1-u6;
      	GENERATE = u1-u6(1);
      	CATEGORICAL = u1-u6;
      	GENCLASSES = c(4);
      	CLASSES = c(4);
      	NOBSERVATIONS = 500;
      	SEED = 1495;
      	NREPS = 1;
        REPSAVE = all;
