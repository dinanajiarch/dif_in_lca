
prob_heatmap <- function(prob_diff) {


prob_diff_table <- prob_diff %>% 
  select(class1, c.param, prob_diff) %>% 
  rename(param = c.param) %>% 
    mutate(items = fct_inorder(param),
         class = fct_inorder(class1)) %>% 
  select(class, items, prob_diff) %>% 
  pivot_wider(names_from = items, values_from = prob_diff) 


subset <- prob_diff_table %>%
    gt() %>%
   cols_label(
     class = "Items"
   ) %>% 
    tab_header(
      title = "Probability Difference"
    ) %>%
    tab_row_group(
      label = "X1 X2 X3", 
      rows = c(1:nrow(prob_diff_table)) 
    ) %>%
    tab_style(
      style = cell_text(
        font = "bold italic" # Apply bold and italic styling
      ),
      locations = cells_row_groups() # Apply style to row subheaders
    ) %>%
    data_color(
      columns = everything(),
      method = "numeric",
      palette = c("white", "red"), # Updated to use a brighter shade of red
      domain = c(0,1),
      apply_to = "fill"
    )  %>%
    fmt_number(columns = 4, decimals = 3) %>%
    opt_table_font(font = "Times New Roman") %>%
    opt_align_table_header(align = "left") %>%
    tab_options(
      table_body.hlines.color = "white",
      table.border.top.color = "black",
      table.border.bottom.color = "black",
      table_body.border.bottom.color = "black",
      heading.border.bottom.color = "black",
      column_labels.border.top.color = "black",
      column_labels.border.bottom.color = "black",
      row_group.border.bottom.color = "black" ,
      row_group.border.top.color = "black"
    ) %>%
  cols_align(
    align = c("center"),
    columns = everything()
  ) %>%
  tab_footnote(
    footnote = md("Red indicates higher probability difference ranging from 0 to 1.")
  )

subset
return(subset)

}



class_heatmap <- function(c, conx) {


prop_table_df <- as.data.frame.matrix(compare_prob(c, conx)$proportion_table)


num_classes <- nrow(prop_table_df)


# Generate class labels dynamically based on num_classes
class_labels <- paste("Class", 1:num_classes)

# Create class size table, renaming columns based on class_labels
class_size_table <- prop_table_df %>% 
  rename_with(~ class_labels, .cols = 1:num_classes) %>% 
  mutate(class = class_labels) %>% 
  relocate(class)


subset <- class_size_table %>%
    gt() %>%
   cols_label(
     class = "Model 1 Class"
   ) %>% 
  tab_spanner(
label = "Model 2 Class",
columns = 2:5
) %>%
    tab_header(
      title = "Class Stability"
    ) %>%
    tab_style(
      style = cell_text(
        font = "bold italic" # Apply bold and italic styling
      ),
      locations = cells_row_groups() # Apply style to row subheaders
    ) %>%
      data_color(
      columns = everything(),
      method = "numeric",
      palette = c("white", "blue"), # Updated to use a brighter shade of blue
      domain = c(0,1),
      apply_to = "fill"
    )  %>%
    fmt_number(columns = 4, decimals = 3) %>%
    opt_table_font(font = "Times New Roman") %>%
    opt_align_table_header(align = "left") %>%
    tab_options(
      table_body.hlines.color = "white",
      table.border.top.color = "black",
      table.border.bottom.color = "black",
      table_body.border.bottom.color = "black",
      heading.border.bottom.color = "black",
      column_labels.border.top.color = "black",
      column_labels.border.bottom.color = "black",
      row_group.border.bottom.color = "black" ,
      row_group.border.top.color = "black"
    ) %>%
  cols_align(
    align = c("center"),
    columns = everything()
  ) %>%
  tab_footnote(
    footnote = md("Blue indicates movement of individuals from Model 1 to Model 2, ranging from 0 to 1.")
  )
subset
return(subset)

}