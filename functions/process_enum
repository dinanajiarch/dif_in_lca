# Define the error messages
error_1 <- "THE STANDARD ERRORS OF THE MODEL PARAMETER ESTIMATES MAY NOT BE"
error_2 <- "ONE OR MORE MULTINOMIAL LOGIT PARAMETERS WERE FIXED TO AVOID SINGULARITY"
error_3 <- "USING MORE RANDOM STARTS MAY RESOLVE THE PROBLEM."

# Initialize a list to store results for all files
results <- list()

# Process each file
for (file_path in mplus_files) {
  # Read the file content
  file_content <- readLines(file_path)
  
  # Initialize a vector to store replication numbers
  replications_with_error <- c()
  
  # Loop through the lines to detect replications with errors
  for (i in seq_along(file_content)) {
    if (grepl(error_1, file_content[i], fixed = TRUE) ||
        grepl(error_2, file_content[i], fixed = TRUE) || 
        grepl(error_3, file_content[i], fixed = TRUE)) {
      # Find the replication number in the previous lines
      replication_line <- grep("REPLICATION", file_content[1:i], value = TRUE)
      if (length(replication_line) > 0) {
        replication_number <- gsub("[: ]", "", gsub("REPLICATION", "", replication_line[length(replication_line)]))
        replications_with_error <- c(replications_with_error, replication_number)
      }
    }
  }
  
  # Remove duplicate replication numbers
  replications_with_error <- unique(replications_with_error)
  
  # Count the number of unique replications with errors
  num_replications <- length(replications_with_error)
  
  # Save results for this file
  results[[file_path]] <- data.frame(
    file = file_path,
    num_replications = num_replications,
    replications_with_error = paste(replications_with_error, collapse = " ")
  )

}

