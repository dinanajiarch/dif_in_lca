# Combine extracted values into a single data frame
combine_extracted_values <- function(data_list) {
  combined_data <- do.call(rbind, lapply(names(data_list), function(file_name) {
    file_data <- data_list[[file_name]]
    do.call(rbind, lapply(names(file_data), function(section_name) {
      section_data <- file_data[[section_name]]
      # Create a data frame with file name and section name for context
      data.frame(
        File = file_name,
        Rep = section_name,
        BIC = section_data["BIC"],
        aBIC = section_data["aBIC"],
        VLMR = section_data["VLMR"],
        Par = section_data["par"],
        LL = section_data["LL"],
        stringsAsFactors = FALSE
      )
    }))
  }))
  
  return(combined_data)
}


